# --- Configuration Supabase ---
# Obtenez ces clés dans Supabase > Settings > API
SUPABASE_URL="https://votresupabase.supabase.co"
SUPABASE_ANON_KEY="votre_cle_anonyme_supabase"

# --- Configuration Prisma / Base de données (Supabase PostgreSQL) ---
# Obtenez l'URL de connexion dans Supabase > Settings > Database (Utilisez l'URL de Connection Pooling en mode Transaction pour Prisma)
DATABASE_URL="postgresql://postgres.[votre-id]:[votre-mot-de-passe]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma a aussi souvent besoin d'une URL directe pour les migrations (si applicable)
# DIRECT_URL="postgresql://postgres.[votre-id]:[votre-mot-de-passe]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Configuration JWT ---
JWT_SECRET="une_cle_secrete_tres_longue_et_securisee"
JWT_EXPIRES_IN="1d"

# --- Autres configurations (ex: GeniusPay) ---
# PAYDUNYA_MASTER_KEY="votre_cle"
# ...
